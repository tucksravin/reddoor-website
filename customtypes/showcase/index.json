{
  "format": "page",
  "id": "showcase",
  "label": "showcase",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "config": {
          "label": "UID"
        },
        "type": "UID"
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "title",
          "placeholder": ""
        }
      },
      "tagline": {
        "type": "Text",
        "config": {
          "label": "tagline",
          "placeholder": ""
        }
      },
      "hero": {
        "type": "Image",
        "config": {
          "label": "hero",
          "constraint": {},
          "thumbnails": []
        }
      },
      "body": {
        "type": "StructuredText",
        "config": {
          "label": "body",
          "placeholder": "",
          "allowTargetBlank": true,
          "multi": "paragraph,preformatted,heading1,heading2,heading3,heading4,heading5,heading6,strong,em,hyperlink,image,embed,list-item,o-list-item,rtl"
        }
      },
      "featuredproject": {
        "type": "Link",
        "config": {
          "label": "featuredProject",
          "select": "document",
          "customtypes": ["project"]
        }
      },
      "featuredImageOverride": {
        "type": "Image",
        "config": {
          "label": "set featured image",
          "constraint": {},
          "thumbnails": []
        }
      },
      "featuredTitleOverride": {
        "type": "Text",
        "config": {
          "label": "set featured title",
          "placeholder": "optional"
        }
      },
      "featuredSubtitleOverride": {
        "type": "Text",
        "config": {
          "label": "set featured subtitle title",
          "placeholder": "optional"
        }
      },
      "projects": {
        "type": "Group",
        "config": {
          "label": "projects",
          "repeat": true,
          "fields": {
            "project": {
              "type": "Link",
              "config": {
                "label": "project",
                "select": "document",
                "customtypes": ["project"]
              }
            },
            "imageOverride": {
              "type": "Image",
              "config": {
                "label": "set image",
                "constraint": {},
                "thumbnails": []
              }
            },
            "titleOverride": {
              "type": "Text",
              "config": {
                "label": "set title",
                "placeholder": "optional"
              }
            },
            "subtitleOverride": {
              "type": "Text",
              "config": {
                "label": "set subtitle",
                "placeholder": "optional"
              }
            }
          }
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {
            "value_block": {
              "type": "SharedSlice"
            },
            "slideshow": {
              "type": "SharedSlice"
            },
            "screen_width_columns": {
              "type": "SharedSlice"
            },
            "content_width_image": {
              "type": "SharedSlice"
            },
            "screen_width_image": {
              "type": "SharedSlice"
            },
            "rich_text": {
              "type": "SharedSlice"
            }
          }
        }
      }
    },
    "SEO & Metadata": {
      "meta_title": {
        "config": {
          "label": "Meta Title",
          "placeholder": "A title of the page used for social media and search engines"
        },
        "type": "Text"
      },
      "meta_description": {
        "config": {
          "label": "Meta Description",
          "placeholder": "A brief summary of the page"
        },
        "type": "Text"
      },
      "meta_image": {
        "config": {
          "constraint": {
            "height": 1260,
            "width": 2400
          },
          "label": "Meta Image",
          "thumbnails": []
        },
        "type": "Image"
      },
      "slices1": {
        "type": "Slices",
        "fieldset": "Slice Zone"
      }
    }
