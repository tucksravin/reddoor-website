{
  "id": "slideshow",
  "type": "SharedSlice",
  "name": "Slideshow",
  "description": "Slideshow",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "initial",
      "description": "Default",
      "imageUrl": "",
      "primary": {
        "label": {
          "type": "Text",
          "config": {
            "label": "label",
            "placeholder": ""
          }
        },
        "body": {
          "type": "StructuredText",
          "config": {
            "label": "body",
            "placeholder": "",
            "allowTargetBlank": true,
            "multi": "paragraph,preformatted,heading1,heading2,heading3,heading4,heading5,heading6,strong,em,hyperlink,image,embed,list-item,o-list-item,rtl"
          }
        },
        "images": {
          "type": "Group",
          "config": {
            "label": "images",
            "repeat": true,
            "fields": {
              "image": {
                "type": "Image",
                "config": {
                  "label": "image",
                  "constraint": {},
                  "thumbnails": []
                }
              }
            }
          }
        },
        "backgroundcolor": {
          "type": "Select",
          "config": {
            "label": "backgroundColor",
            "placeholder": "",
            "options": ["white", "gray", "red", "paper", "paper-red"],
            "default_value": "white"
          }
        },
        "isFullContentWidth": {
          "type": "Boolean",
          "config": {
            "label": "width",
            "placeholder_false": "80% content width, floats right",
            "placeholder_true": "full content width",
            "default_value": true
          }
        },
        "hide": {
          "type": "Boolean",
          "config": {
            "label": "hide",
            "placeholder_false": "visible",
            "placeholder_true": "hidden",
            "default_value": false
          }
        },
        "isAnimated": {
          "type": "Boolean",
          "config": {
            "label": "animate in",
            "placeholder_false": "not animated",
            "placeholder_true": "animated",
            "default_value": true
          }
        },
        "hasNavDots": {
          "type": "Boolean",
          "config": {
            "label": "hasNavDots",
            "placeholder_false": "no dots",
            "placeholder_true": "dots",
            "default_value": true
          }
        }
      },
      "items": {}
    }
  ]
}
